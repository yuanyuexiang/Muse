# 复制为 .env 后填写。切勿把 .env 提交进仓库（见 .gitignore）。

# ── 数据库 ────────────────────────────────────────────────
# 本地直接跑 uvicorn 用 localhost；compose 里 backend/bot 会被覆盖为内部 postgres:5432
# 宿主端口用 55432（避开本机已占用的 5432），与 docker-compose.yml 的映射一致
DATABASE_URL=postgresql+asyncpg://muse:muse@localhost:55432/muse

# ── 存储（媒体文件）───────────────────────────────────────
# local = 本地卷（Phase 1 默认）；minio = 切到 MinIO
STORAGE_BACKEND=local
STORAGE_DIR=./data/storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=muse
MINIO_SECRET_KEY=muse12345
MINIO_BUCKET=muse-media

# ── LLM（OpenAI 兼容，多模态）────────────────────────────
# 不填则整理步返回占位草稿，管线仍可端到端跑通
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_MODEL=qwen-vl-max

# ── 企业微信智能机器人（Phase 1，长连接）─────────────────
# 管理后台 → 智能机器人 → API 模式 → 长连接 获取
WECOM_CORPID=
WECOM_BOT_ID=
WECOM_BOT_SECRET=

# ── 企业微信会话存档（Phase 2，暂空）─────────────────────
WECOM_ARCHIVE_SECRET=
